# --- Gemini API ---
GEMINI_API_KEY=key1,key2,key3   # comma-separated for fail-over

# --- Default Shopify store (used when no shopDomain is passed) ---
SHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_storefront_access_token

SHOPIFY_ADMIN_API_VERSION=2026-01

# --- MongoDB (Atlas) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=dermatics

# --- Admin usage analytics endpoints ---
ADMIN_API_KEY=set-a-long-random-string
ADMIN_RATE_LIMIT_MAX=60
ADMIN_RATE_LIMIT_WINDOW_MS=60000

# --- Optional: override Gemini pricing (USD per 1M tokens) ---
# PRICE_GEMINI_2_5_FLASH_INPUT=0.30
# PRICE_GEMINI_2_5_FLASH_OUTPUT=2.50
